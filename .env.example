# NVIDIA API 配置（必填）
# 从 https://build.nvidia.com/ 获取
NVIDIA_API_KEY=your_api_key_here

# Twitter 认证（可选）
# 从浏览器 Cookie 中获取
AUTH_TOKEN=your_auth_token
CT0=your_ct0_value

# 浏览器配置（可选）
# 设置为 true 可在后台运行（无 GUI）
HEADLESS=false

# 小红书 Cookie 文件位置（可选）
COOKIES_FILE=./xhs_cookies.json

# 日志级别（可选）
LOG_LEVEL=info
